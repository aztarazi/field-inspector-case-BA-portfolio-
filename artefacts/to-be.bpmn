      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="A_deliver_di" bpmnElement="A_deliver">
        <omgdc:Bounds x="920" y="140" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_insp_di" bpmnElement="End_insp">
        <omgdc:Bounds x="1072" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1050" y="205" width="86" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="fi1_di" bpmnElement="fi1">
