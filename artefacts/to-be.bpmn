<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:storm="http://storm.bpmn2.ru/ns" id="Definitions_tobe" targetNamespace="http://bpmn.io/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <collaboration id="Collaboration_tobe">
    <participant id="P_insp" name="Полевой инспектор (планшет компании)" processRef="Process_insp" />
    <participant id="P_lims" name="Информационная система LIMS" processRef="Process_lims" />
    <participant id="P_lab" name="Лаборант" processRef="Process_lab" />
    <messageFlow id="M_api" name="POST /api/v1/samples" sourceRef="A_send" targetRef="E_lims_start" />
    <messageFlow id="M_deliver" name="Опечатанная проба" sourceRef="A_deliver" targetRef="E_lab_start" />
  </collaboration>
  <process id="Process_insp" isExecutable="false">
    <startEvent id="Start_insp" name="Получено задание на отбор пробы">
      <outgoing>fi1</outgoing>
    </startEvent>
    <userTask id="A_otbor" name="Отобрать пробу">
      <incoming>fi1</incoming>
      <outgoing>fi2</outgoing>
    </userTask>
    <userTask id="A_form" name="Заполнить форму пробы в приложении">
      <incoming>fi2</incoming>
      <outgoing>fi3</outgoing>
    </userTask>
    <sendTask id="A_send" name="Отправить данные пробы по API">
      <incoming>fi3</incoming>
      <outgoing>fi4</outgoing>
    </sendTask>
    <userTask id="A_qr" name="Напечатать QR и опечатать пробу">
      <incoming>fi4</incoming>
      <outgoing>fi5</outgoing>
    </userTask>
    <userTask id="A_deliver" name="Доставить пробу в лабораторию">
      <incoming>fi5</incoming>
      <outgoing>fi6</outgoing>
    </userTask>
    <endEvent id="End_insp" name="Проба передана в лабораторию">
      <incoming>fi6</incoming>
    </endEvent>
    <sequenceFlow id="fi1" sourceRef="Start_insp" targetRef="A_otbor" />
    <sequenceFlow id="fi2" sourceRef="A_otbor" targetRef="A_form" />
    <sequenceFlow id="fi3" sourceRef="A_form" targetRef="A_send" />
    <sequenceFlow id="fi4" sourceRef="A_send" targetRef="A_qr" />
    <sequenceFlow id="fi5" sourceRef="A_qr" targetRef="A_deliver" />
    <sequenceFlow id="fi6" sourceRef="A_deliver" targetRef="End_insp" />
  </process>
  <process id="Process_lims" isExecutable="false">
    <startEvent id="E_lims_start" name="Получен запрос POST /api/v1/samples">
      <outgoing>fd1</outgoing>
      <messageEventDefinition id="MED_tobe_lims" />
    </startEvent>
    <serviceTask id="A_validate" name="Валидировать и смаппить данные">
      <incoming>fd1</incoming>
      <outgoing>fd2</outgoing>
    </serviceTask>
    <exclusiveGateway id="G_valid" name="Данные валидны?" default="fd3">
      <incoming>fd2</incoming>
      <outgoing>fd3</outgoing>
      <outgoing>fd5</outgoing>
    </exclusiveGateway>
    <exclusiveGateway id="G_unique" name="Пломба уникальна?" default="fduq_yes">
      <incoming>fd3</incoming>
      <outgoing>fduq_yes</outgoing>
      <outgoing>fduq_no</outgoing>
    </exclusiveGateway>
    <serviceTask id="A_create" name="Создать карточку пробы">
      <incoming>fduq_yes</incoming>
      <outgoing>fd4</outgoing>
      <dataOutputAssociation id="DataOutputAssociation_tobe">
        <targetRef>DataStore_1</targetRef>
      </dataOutputAssociation>
    </serviceTask>
    <endEvent id="End_lims_ok" name="Карточка создана (HTTP 201)">
      <incoming>fd4</incoming>
    </endEvent>
    <serviceTask id="A_400" name="Сформировать ответ HTTP 400">
      <incoming>fd5</incoming>
      <outgoing>fd6</outgoing>
    </serviceTask>
    <endEvent id="End_lims_err" name="Запрос отклонён (HTTP 400)">
      <incoming>fd6</incoming>
    </endEvent>
    <serviceTask id="A_409" name="Сформировать ответ HTTP 409 (дубль пломбы)">
      <incoming>fduq_no</incoming>
      <outgoing>fd7</outgoing>
    </serviceTask>
    <endEvent id="End_lims_409" name="Запрос отклонён (HTTP 409)">
      <incoming>fd7</incoming>
    </endEvent>
    <dataStoreReference id="DataStore_1" name="MS SQL Server (dbo.Samples)" />
    <sequenceFlow id="fd1" sourceRef="E_lims_start" targetRef="A_validate" />
    <sequenceFlow id="fd2" sourceRef="A_validate" targetRef="G_valid" />
    <sequenceFlow id="fd3" name="Да" sourceRef="G_valid" targetRef="G_unique" />
    <sequenceFlow id="fd5" name="Нет" sourceRef="G_valid" targetRef="A_400" />
    <sequenceFlow id="fduq_yes" name="Да" sourceRef="G_unique" targetRef="A_create" />
    <sequenceFlow id="fduq_no" name="Нет" sourceRef="G_unique" targetRef="A_409" />
    <sequenceFlow id="fd4" sourceRef="A_create" targetRef="End_lims_ok" />
    <sequenceFlow id="fd6" sourceRef="A_400" targetRef="End_lims_err" />
    <sequenceFlow id="fd7" sourceRef="A_409" targetRef="End_lims_409" />
  </process>
  <process id="Process_lab" isExecutable="false">
    <startEvent id="E_lab_start" name="Проба доставлена">
      <outgoing>fl1</outgoing>
      <messageEventDefinition id="MED_tobe_lab" />
    </startEvent>
    <userTask id="A_scan" name="Сканировать QR-код пломбы">
      <incoming>fl1</incoming>
      <outgoing>fl2</outgoing>
    </userTask>
    <userTask id="A_match" name="Сверить пробу с карточкой в LIMS">
      <incoming>fl2</incoming>
      <outgoing>fl3</outgoing>
    </userTask>
    <userTask id="A_tests" name="Начать лабораторные испытания">
      <incoming>fl3</incoming>
      <outgoing>fl4</outgoing>
    </userTask>
    <endEvent id="End_lab" name="Проба принята в работу">
      <incoming>fl4</incoming>
    </endEvent>
    <sequenceFlow id="fl1" sourceRef="E_lab_start" targetRef="A_scan" />
    <sequenceFlow id="fl2" sourceRef="A_scan" targetRef="A_match" />
    <sequenceFlow id="fl3" sourceRef="A_match" targetRef="A_tests" />
    <sequenceFlow id="fl4" sourceRef="A_tests" targetRef="End_lab" />
  </process>
  <bpmndi:BPMNDiagram id="BpmnDiagram_tobe">
    <bpmndi:BPMNPlane id="BpmnPlane_tobe" bpmnElement="Collaboration_tobe">
      <bpmndi:BPMNShape id="P_insp_di" bpmnElement="P_insp" isHorizontal="true">
        <omgdc:Bounds x="152" y="80" width="1500" height="300" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_insp_di" bpmnElement="Start_insp">
        <omgdc:Bounds x="232" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="210" y="205" width="86" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
